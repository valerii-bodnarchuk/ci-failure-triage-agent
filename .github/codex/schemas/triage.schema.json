{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CI Failure Triage Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "category",
    "rootCause",
    "confidence",
    "affectedFiles",
    "riskLevel",
    "requiresHumanApproval",
    "proposedPatchSummary",
    "verificationCommands"
  ],
  "properties": {
    "category": {
      "type": "string",
      "enum": ["app_bug", "test_bug", "dependency", "config", "flaky_test", "unknown"]
    },
    "rootCause": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "affectedFiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "riskLevel": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "requiresHumanApproval": {
      "type": "boolean"
    },
    "proposedPatchSummary": {
      "type": "string"
    },
    "verificationCommands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
