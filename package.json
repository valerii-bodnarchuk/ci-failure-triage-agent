{
  "name": "ci-failure-triage-agent",
  "version": "0.1.0",
  "private": true,
  "description": "CI Failure Triage Agent demo project.",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "triage:collect": "node --import tsx scripts/codex/collect-ci-context.ts",
    "triage:approval": "node --import tsx scripts/codex/record-approval.ts",
    "triage:exec": "bash scripts/codex/run-triage-exec.sh",
    "triage:validate": "node --import tsx scripts/codex/validate-triage-report.ts",
    "codex:guard": "node --import tsx scripts/codex/pre-tool-guard.ts"
  },
  "devDependencies": {
    "@types/node": "20.19.21",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
